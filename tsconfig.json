{
    "compileOnSave": false,
    "compilerOptions": {
        "baseUrl": "./",
        "outDir": "./dist/out-tsc",
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "target": "es2022",
        "typeRoots": ["node_modules/@types"],
        "lib": ["es2022", "dom"],
        "paths": {
            "@healthcatalyst/cashmere": ["dist/cashmere"],
            "@healthcatalyst/cashmere-examples": ["dist/cashmere-examples"]
        }
    },
    "ts-node": {
        "compilerOptions": {
            "module": "commonjs",
            "moduleResolution": "node"
        }
    }
}
